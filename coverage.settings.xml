<?xml version="1.0" encoding="utf-8"?>
<Configuration>
  <CodeCoverage>
    <!-- Measure only the Functions worker assembly, not the test assembly or dependencies. -->
    <ModulePaths>
      <Include>
        <ModulePath>.*[\\/]Functions\.dll$</ModulePath>
      </Include>
    </ModulePaths>
    <Attributes>
      <Exclude>
        <Attribute>^System\.CodeDom\.Compiler\.GeneratedCodeAttribute$</Attribute>
      </Exclude>
    </Attributes>
    <Sources>
      <Exclude>
        <Source>.*[\\/]Program\.cs$</Source>
      </Exclude>
    </Sources>
  </CodeCoverage>
</Configuration>
